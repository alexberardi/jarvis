[Unit]
Description=OpenClaw gateway health watchdog — probes + auto-recovers the gateway
After=openclaw-gateway.service

[Service]
Type=oneshot
Environment=HOME=/home/pi
Environment=PATH=/usr/bin:/home/pi/.local/bin:/usr/local/bin:/bin
ExecStart=/usr/bin/python3 /home/pi/code/jarvis-tracker/health_watchdog.py
StandardOutput=journal
StandardError=journal
