# ============================================================================
# Jarvis LLM Proxy API — Remote Deployment Environment
# ============================================================================
# Generated by setup.sh. Edit manually if needed.
#
# Sections:
#   1. Main server connection (service discovery)
#   2. Auth credentials (filled by setup.sh)
#   3. Internal tokens (auto-generated)
#   4. Data stores (PostgreSQL, Redis)
#   5. Model configuration (filled by setup.sh from preset)
#   6. Server ports & image version
# ============================================================================

# --- 1. Main Server Connection ---
# URL of jarvis-config-service on the main server
JARVIS_CONFIG_URL=http://__MAIN_SERVER_IP__:7700

# Tell config-client to request remote-style URLs
JARVIS_CONFIG_URL_STYLE=remote

# --- 2. Auth Credentials ---
# App-to-app auth (registered by setup.sh)
JARVIS_APP_ID=jarvis-llm-proxy-api
JARVIS_APP_KEY=__APP_KEY__

# Same credentials for auth validation
JARVIS_AUTH_APP_ID=jarvis-llm-proxy-api
JARVIS_AUTH_APP_KEY=__APP_KEY__

# Auth service URL (on the main server)
JARVIS_AUTH_BASE_URL=http://__MAIN_SERVER_IP__:7701

# --- 3. Internal Tokens ---
# Inter-container auth (auto-generated by setup.sh)
MODEL_SERVICE_TOKEN=__MODEL_SERVICE_TOKEN__
LLM_PROXY_INTERNAL_TOKEN=__LLM_PROXY_INTERNAL_TOKEN__

# --- 4. Data Stores ---
# PostgreSQL (on main server or dedicated DB host)
DATABASE_URL=postgresql+psycopg2://__DB_USER__:__DB_PASS__@__DB_HOST__:__DB_PORT__/__DB_NAME__
MIGRATIONS_DATABASE_URL=postgresql+psycopg2://__DB_USER__:__DB_PASS__@__DB_HOST__:__DB_PORT__/__DB_NAME__

# Redis (on main server or dedicated host)
REDIS_URL=redis://:__REDIS_PASS__@__REDIS_HOST__:__REDIS_PORT__/0

# --- 5. Model Configuration ---
# These env vars are the bootstrap fallback; settings DB is the source of truth.
# After first startup, setup.sh syncs these to the DB via /settings/sync-from-env.
JARVIS_MODEL_NAME=__MODEL_NAME__
JARVIS_MODEL_BACKEND=__MODEL_BACKEND__
JARVIS_MODEL_CHAT_FORMAT=__MODEL_CHAT_FORMAT__
JARVIS_MODEL_CONTEXT_WINDOW=__MODEL_CONTEXT_WINDOW__
JARVIS_MODEL_STOP_TOKENS=__MODEL_STOP_TOKENS__

# --- 5b. Multi-GPU / vLLM Configuration ---
# vLLM tensor parallelism (number of GPUs, empty = default 1)
JARVIS_VLLM_TENSOR_PARALLEL_SIZE=__VLLM_TENSOR_PARALLEL__
# vLLM GPU memory utilization per GPU (0.0-1.0, empty = default 0.9)
JARVIS_VLLM_GPU_MEMORY_UTILIZATION=__VLLM_GPU_MEMORY_UTIL__
# vLLM tokenizer override (required for GGUF files, HF repo ID)
JARVIS_VLLM_TOKENIZER=__VLLM_TOKENIZER__
# vLLM LoRA: 0 to disable (required for MoE models like Mixtral with tensor parallel)
JARVIS_VLLM_MAX_LORAS=__VLLM_MAX_LORAS__
# GGUF llama.cpp multi-GPU: comma-separated VRAM proportions (e.g., "0.50,0.50")
JARVIS_GGUF_TENSOR_SPLIT=__GGUF_TENSOR_SPLIT__
# GGUF llama.cpp split mode: 1=layer (default), 2=row
JARVIS_GGUF_SPLIT_MODE=__GGUF_SPLIT_MODE__
# GGUF llama.cpp main GPU index for scratch buffers
JARVIS_GGUF_MAIN_GPU=__GGUF_MAIN_GPU__

# Path to models directory (mounted read-only into containers)
MODELS_DIR=./.models

# --- 6. Server Ports & Image Version ---
SERVER_HOST=0.0.0.0
SERVER_PORT=7704
MODEL_SERVICE_PORT=7705
RUN_MODEL_SERVICE=true
LLM_PROXY_VERSION=dev
